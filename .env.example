# Environment Configuration Template
# Copy this file to .env.development or .env.production and update values

# The base URL of the API server
# - Development: http://[YOUR_LAN_IP]:3000 (e.g., 192.168.20.149:3000)
# - Production: https://tawreedportal-production.up.railway.app
EXPO_PUBLIC_API_URL=http://192.168.20.149:3000

# Application environment for conditional logic
# Values: "development" | "production"
EXPO_PUBLIC_APP_ENV=development

# Optional: Expo Push Notifications Project ID
# Default: "tawreed" (currently hardcoded as fallback)
# EXPO_PUBLIC_PROJECT_ID=tawreed

# ============================================
# Firebase Configuration (for FCM)
# ============================================
# 
# SECURITY NOTE: 
# - Backend credentials (.key fields) should ONLY be in .env (never committed)
# - Frontend credentials (API_KEY, APP_ID) are public and safe for frontend
# - Use Google Cloud Secret Manager in production
#

# Backend Firebase Credentials (BACKEND ONLY - DO NOT EXPOSE)
FIREBASE_PROJECT_ID=tawreed-d7550
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@tawreed-d7550.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY_ID=dcac4fc11052be79bb3a0f381a2aec97d1740005
# For FIREBASE_PRIVATE_KEY: paste entire private key between quotes, keeping newlines
# Replace \n with actual newlines when pasting
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Frontend Firebase Config (PUBLIC - SAFE FOR FRONTEND)
EXPO_PUBLIC_FIREBASE_PROJECT_ID=tawreed-d7550
EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_PUBLIC_API_KEY_HERE
EXPO_PUBLIC_FIREBASE_APP_ID=1:116745950976293819044:android:YOUR_APP_ID

# Node environment
NODE_ENV=development
